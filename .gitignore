# Environment & Secrets
.env
*.env.local
*.env.production

# Database dumps — NEVER commit
*.sql
*.sql.txt
*.sql.gz
*.sql.bak
# Migration files are schema DDL, not data — allow them
!scripts/migrations/*.sql

# Logs
logs/
*.log

# Debug & Test files
*debug*
*test_*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.sublime-*

# Dependencies (if using composer later)
/vendor/
/node_modules/

# Uploaded files (user data)
uploads/
ghom/uploads/
pardis/uploads/
chat/uploads/
pardis/includes/mpdf/
pardis/includes/libraries/

# Content-addressable storage — actual file blobs never committed,
# but keep directory layout and .htaccess/serve.php
/storage/*
!/storage/.gitkeep
!/storage/.htaccess
!/storage/serve.php

# Backup copies
* copy*
*Copy*
*.bak
*.backup
*.orig

# PHP info
info.php

# Build artifacts
/dist/
/build/

# Cache
/cache/
*.cache
composer.lock
/.phpunit.cache
