# ==============================================================
# AlumGlass Project Management — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# ==============================================================

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_COMMON_NAME=alumglas_common
DB_GHOM_NAME=alumglas_hpc
DB_PARDIS_NAME=alumglas_pardis
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ---- Telegram Integration ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CRON_SECRET=generate_a_random_32_char_string

# ---- Weather API ----
WEATHER_API_KEY=your_weather_api_key_here

# ---- Application ----
APP_ENV=production
APP_DEBUG=false
APP_URL=https://alumglass.ir
APP_TIMEZONE=Asia/Tehran

# ---- Security ----
SESSION_LIFETIME=3600
LOGIN_LOCKOUT_TIME=3600
LOGIN_ATTEMPTS_LIMIT=5

# ---- File Upload ----
UPLOAD_MAX_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,csv,xlsx
